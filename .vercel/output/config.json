{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/checkout",
      "dest": "/checkout"
    },
    {
      "src": "/api/products",
      "dest": "/api/products"
    },
    {
      "src": "/api/categories",
      "dest": "/api/categories"
    },
    {
      "src": "/api/admin/upload",
      "dest": "/api/admin/upload"
    },
    {
      "src": "/api/admin/products",
      "dest": "/api/admin/products"
    },
    {
      "src": "/api/admin/login",
      "dest": "/api/admin/login"
    },
    {
      "src": "/api/admin/categories/upload",
      "dest": "/api/admin/categories/upload"
    },
    {
      "src": "/api/admin/categories",
      "dest": "/api/admin/categories"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}